pipeline {
    agent any
    stages {
        stage ("Cloning code from SCM ") {
            steps {
                git branch: "dev", url: "https://github.com/ishunrzb09/ankit_tuts.git"
            }
        }

        stage ("Creating Virtual ENV") {
            steps {
                sh """#!/bin/bash
                mkdir /var/lib/jenkins/envs/
		        virtualenv /var/lib/jenkins/envs/${JOB_NAME}
		        """
            }
        }


        stage ("Installing Requirments") {
            steps {
                sh """#!/bin/bash
		        source /var/lib/jenkins/envs/${JOB_NAME}/bin/activate
		        pip install -r requirements.txt
		        """
            }
        }

        stage ("Checking black") {
            steps {
                sh """#!/bin/bash
		        source /var/lib/jenkins/envs/${JOB_NAME}/bin/activate
		        black --check . --color -v
		        """
            }
        }

        stage ("Checking isort") {
            steps {
                sh """#!/bin/bash
		        source /var/lib/jenkins/envs/${JOB_NAME}/bin/activate
		        isort --check .
		        """
            }
        }

        stage ("Checking Django test") {
            steps {
                sh """#!/bin/bash
		        source /var/lib/jenkins/envs/${JOB_NAME}/bin/activate
		        python medical_test/manage.py test
		        """
            }
        }

        stage ("Building Docker image") {
            steps {
                sh "docker build -t ishunrzb09/${JOB_NAME}:V_${BUILD_NUMBER} ."
            }
        }

        stage ("Publish docker images") {
            steps {
                sh "docker push ishunrzb09/${JOB_NAME}:V_${BUILD_NUMBER}" 
            }
        }

        stage ("Removing Docker image from local system") {
            steps {
                sh "docker rmi ishunrzb09/${JOB_NAME}:V_${BUILD_NUMBER}" 
            }
        }
        
        stage ("Pulling Docker images") {
            steps {
                sh "docker pull ishunrzb09/${JOB_NAME}:V_${BUILD_NUMBER}" 
            }
        }

        stage ("Removing Old Docker container") {
            steps {
                sh "docker rm -f ankit_new_latest" 
            }
        }

        stage ("Deploying Docker Container") {
            steps {
                sh "docker run -itd --name=ankit_new_latest -p 15000:8000 ishunrzb09/${JOB_NAME}:V_${BUILD_NUMBER}" 
            }
        }


    }
}