pipeline {
    agent any
    stages {
        stage ("Cloning code from SCM ") {
            steps {
                git branch: 'dev', url: 'https://github.com/ishunrzb09/ankit_tuts.git'
            }
        }

        stage ("Installing Requirments") {
            steps {
                sh """#!/bin/bash
		        pip install -r requirements.txt
		        """
            }
        }

    }
}